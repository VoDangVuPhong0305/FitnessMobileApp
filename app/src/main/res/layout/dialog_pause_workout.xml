<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6121721">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="26dp"
        android:paddingEnd="26dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tạm dừng"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnRestartCurrentExercise"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_pause_action"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Khởi động lại bài tập này"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnExitWorkout"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_pause_action"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Thoát"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnContinueWorkout"
            android:layout_width="match_parent"
            android:layout_height="74dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_pause_continue"
            android:gravity="center_vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="Tiếp tục tập luyện"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>