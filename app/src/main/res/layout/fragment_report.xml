<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <!-- NỀN XANH KÉO DÀI XUỐNG DƯỚI -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:background="#343B5C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- HEADER CỐ ĐỊNH: phần này không bị cuộn và không bị card che -->
    <LinearLayout
        android:id="@+id/headerFixed"
        android:layout_width="0dp"
        android:layout_height="175dp"
        android:elevation="0dp"
        android:background="#343B5C"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtReportTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hãy phát huy!"
            android:textColor="#FFFFFF"
            android:textSize="30sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/tabCalendar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTabCalendar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <View
                    android:id="@+id/lineCalendar"
                    android:layout_width="46dp"
                    android:layout_height="5dp"
                    android:layout_marginTop="8dp"
                    android:background="#F6E96B" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="42dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTabWeight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cân nặng"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp" />

                <View
                    android:id="@+id/lineWeight"
                    android:layout_width="78dp"
                    android:layout_height="5dp"
                    android:layout_marginTop="8dp"
                    android:background="#00FFFFFF" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- NỘI DUNG CUỘN: bắt đầu bên dưới Lịch/Cân nặng nên không che tab nữa -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollReport"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerFixed"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layoutReportContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="0dp"
            android:paddingBottom="28dp">

            <!-- PHẦN LỊCH -->
            <LinearLayout
                android:id="@+id/sectionCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CARD THỐNG KÊ NHANH -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSummary"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tập luyện"
                                android:textColor="#666666"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#222222"
                                android:textSize="34sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="55dp"
                            android:background="#EEEEEE" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calo"
                                android:textColor="#666666"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="#222222"
                                android:textSize="34sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="55dp"
                            android:background="#EEEEEE" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thời gian"
                                android:textColor="#666666"
                                android:textSize="16sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#222222"
                                android:textSize="34sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD LỊCH THÁNG -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="thg 6 2026"
                            android:textColor="#222222"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:columnCount="7"
                            android:useDefaultMargins="true">

                            <!-- Hàng thứ -->
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="CN" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th2" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th3" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th4" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th5" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th6" android:textColor="#888888" android:textSize="15sp" />
                            <TextView android:layout_width="0dp" android:layout_height="40dp" android:layout_columnWeight="1" android:gravity="center" android:text="Th7" android:textColor="#888888" android:textSize="15sp" />

                            <!-- Ngày trong tháng -->
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="1" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="2" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="3" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="4" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="5" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="6" android:textColor="#999999" android:textSize="18sp" />

                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="7" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="8" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="9" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="10" android:textColor="#222222" android:textSize="20sp" android:textStyle="bold" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="11" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="12" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="13" android:textColor="#999999" android:textSize="18sp" />

                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="14" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="15" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="16" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="17" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="18" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="19" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="20" android:textColor="#999999" android:textSize="18sp" />

                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="21" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="22" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="23" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="24" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="25" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="26" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="27" android:textColor="#999999" android:textSize="18sp" />

                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="28" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="29" android:textColor="#999999" android:textSize="18sp" />
                            <TextView android:layout_width="0dp" android:layout_height="50dp" android:layout_columnWeight="1" android:gravity="center" android:text="30" android:textColor="#999999" android:textSize="18sp" />
                        </GridLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD LỊCH SỬ TẬP LUYỆN -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Lịch sử"
                                android:textColor="#222222"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xem tất cả"
                                android:textColor="#52B36B"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:background="#EEEEEE" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:text="7 thg 6 - 13 thg 6          3 Lần tập 01:08"
                            android:textColor="#999999"
                            android:textSize="16sp" />

                        <!-- Item lịch sử 1 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tập Toàn Thân Ngày 1"
                                    android:textColor="#222222"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="20:49      00:10      0.0 Calo"
                                    android:textColor="#777777"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="18dp"
                            android:background="#EEEEEE" />

                        <!-- Item lịch sử 2 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Tập Toàn Thân Ngày 1"
                                    android:textColor="#222222"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="10dp"
                                    android:text="20:44      00:41      12.6 Calo"
                                    android:textColor="#777777"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- PHẦN CÂN NẶNG -->
            <LinearLayout
                android:id="@+id/sectionWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <!-- CARD CÂN NẶNG -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cân nặng  (kg)        +"
                            android:textColor="#222222"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Hiện tại\n76.0"
                                android:textColor="#222222"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="30 ngày trước\n0.0"
                                android:textColor="#222222"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:text="Trung bình năm\n76.0"
                                android:textColor="#222222"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:gravity="center"
                            android:text="Biểu đồ cân nặng"
                            android:textColor="#AAAAAA"
                            android:textSize="16sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD BMI -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="BMI  (kg/m²)"
                                android:textColor="#222222"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chỉnh sửa"
                                android:textColor="#999999"
                                android:textSize="16sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            android:layout_marginTop="18dp"
                            android:background="#5F6774"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="26.3"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />

                        <!-- DẢI MÀU BMI -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="18dp"
                            android:layout_marginTop="18dp"
                            android:orientation="horizontal">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                app:cardBackgroundColor="#496BFF"
                                app:cardCornerRadius="9dp" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="4dp"
                                android:layout_weight="1"
                                app:cardBackgroundColor="#5F93FF"
                                app:cardCornerRadius="9dp" />

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
