<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_centerVertical="true"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Quay lại"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="NGÀY 1"
                android:textColor="#2E7D32"
                android:textSize="26sp"
                android:textStyle="bold"/>

        </RelativeLayout>

        <!-- Chọn chế độ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnStandard"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Tiêu chuẩn"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#4CAF50"/>

            <Button
                android:id="@+id/btnVegetarian"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Ăn chay"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#4CAF50"
                android:backgroundTint="#FFFFFF"/>

        </LinearLayout>

        <!-- Bữa sáng -->
        <TextView
            android:id="@+id/tvBreakfast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:padding="20dp"
            android:textSize="18sp"
            android:textColor="#222222"
            android:lineSpacingExtra="6dp"
            android:text="Bữa sáng..." />

        <!-- Bữa nhẹ -->
        <TextView
            android:id="@+id/tvSnack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:padding="20dp"
            android:textSize="18sp"
            android:textColor="#222222"
            android:lineSpacingExtra="6dp"
            android:text="Bữa nhẹ..." />

        <!-- Bữa trưa -->
        <TextView
            android:id="@+id/tvLunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:padding="20dp"
            android:textSize="18sp"
            android:textColor="#222222"
            android:lineSpacingExtra="6dp"
            android:text="Bữa trưa..." />

        <!-- Bữa tối -->
        <TextView
            android:id="@+id/tvDinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:background="@android:color/white"
            android:elevation="4dp"
            android:padding="20dp"
            android:textSize="18sp"
            android:textColor="#222222"
            android:lineSpacingExtra="6dp"
            android:text="Bữa tối..." />

        <!-- Nút hoàn thành -->
        <ImageView
            android:id="@+id/btnCheck"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:padding="15dp"
            android:src="@drawable/ic_check_green"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Hoàn thành ngày"/>

    </LinearLayout>

</ScrollView>