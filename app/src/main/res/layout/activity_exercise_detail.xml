<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="96dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/btnBackExercise"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="←"
                android:textColor="#333333"
                android:textSize="38sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif" />

            <!-- Tabs Hoạt hình / Video -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tabAnimation"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTabAnimation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Hoạt hình"
                        android:textColor="#222222"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif" />

                    <View
                        android:id="@+id/lineAnimation"
                        android:layout_width="48dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="6dp"
                        android:background="#7B61FF" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabYoutube"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTabYoutube"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="Video"
                        android:textColor="#666666"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif" />

                    <View
                        android:id="@+id/lineYoutube"
                        android:layout_width="48dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="6dp"
                        android:background="#7B61FF"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- Khung video / hoạt hình -->
            <FrameLayout
                android:id="@+id/videoContainer"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_video_container"
                android:padding="8dp">

                <VideoView
                    android:id="@+id/videoExercise"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/txtVideoEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Chưa có hoạt hình"
                    android:textColor="#999999"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:includeFontPadding="false"
                android:text="Tên bài tập"
                android:textColor="#2D2D2D"
                android:textSize="25sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif" />

            <!-- Dòng thời lượng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="Thời lượng"
                    android:textColor="#333333"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/btnMinus"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_time_button"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="−"
                    android:textColor="#7B61FF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/txtExerciseDuration"
                    android:layout_width="92dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="00:30"
                    android:textColor="#444444"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <TextView
                    android:id="@+id/btnPlus"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_time_button"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="+"
                    android:textColor="#7B61FF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtExerciseDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:includeFontPadding="false"
                android:lineSpacingExtra="2dp"
                android:lineSpacingMultiplier="1.0"
                android:text="Mô tả bài tập"
                android:textColor="#777777"
                android:textSize="15sp"
                android:fontFamily="sans-serif" />

        </LinearLayout>
    </ScrollView>

    <!-- Thanh chuyển bài phía dưới -->
    <LinearLayout
        android:id="@+id/layoutBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="34dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp">

        <!-- Cụm chuyển bài bên trái -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPreviousExercise"
                android:layout_width="30dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="←"
                android:textColor="#7B61FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:translationY="-2dp"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/txtExerciseCounter"
                android:layout_width="80dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="1 / 7"
                android:textColor="#111111"
                android:textSize="21sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/btnNextExercise"
                android:layout_width="30dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="→"
                android:textColor="#7B61FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:translationY="-2dp"
                android:fontFamily="sans-serif" />

        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Nút đóng bên phải -->
        <TextView
            android:id="@+id/btnCloseExercise"
            android:layout_width="168dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_start_button"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="ĐÓNG"
            android:textColor="#FFFFFF"
            android:textSize="19sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif" />

    </LinearLayout>

</FrameLayout>