<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="115dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="34dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/btnBackExercise"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:text="←"
                android:textColor="#333333"
                android:textSize="40sp"
                android:textStyle="bold" />

            <!-- Tabs Hoạt hình / Video -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tabAnimation"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTabAnimation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hoạt hình"
                        android:textColor="#222222"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/lineAnimation"
                        android:layout_width="48dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:background="#7B61FF" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabYoutube"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtTabYoutube"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Video"
                        android:textColor="#222222"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/lineYoutube"
                        android:layout_width="48dp"
                        android:layout_height="4dp"
                        android:layout_marginTop="8dp"
                        android:background="#7B61FF"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- Khung video lớn -->
            <FrameLayout
                android:id="@+id/videoContainer"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_video_container"
                android:padding="8dp">

                <VideoView
                    android:id="@+id/videoExercise"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center" />

                <TextView
                    android:id="@+id/txtVideoEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Chưa có hoạt hình"
                    android:textColor="#999999"
                    android:textSize="18sp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/txtExerciseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="Tên bài tập"
                android:textColor="#2D2D2D"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Dòng thời lượng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thời lượng"
                    android:textColor="#333333"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnMinus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_time_button"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="#7B61FF"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtExerciseDuration"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="00:30"
                    android:textColor="#444444"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnPlus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_time_button"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#7B61FF"
                    android:textSize="30sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtExerciseDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:lineSpacingExtra="8dp"
                android:text="Mô tả bài tập"
                android:textColor="#777777"
                android:textSize="16sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Thanh chuyển bài phía dưới -->
    <LinearLayout
        android:id="@+id/layoutBottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="34dp"
        android:paddingEnd="28dp"
        android:paddingBottom="16dp">

        <!-- Cụm chuyển bài bên trái -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnPreviousExercise"
                android:layout_width="30dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="←"
                android:textColor="#7B61FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:translationY="-2dp" />

            <TextView
                android:id="@+id/txtExerciseCounter"
                android:layout_width="70dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="1 / 21"
                android:textColor="#444444"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnNextExercise"
                android:layout_width="30dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="→"
                android:textColor="#7B61FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:translationY="-2dp" />

        </LinearLayout>

        <!-- Khoảng cách lớn giữa cụm chuyển bài và nút ĐÓNG -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Nút đóng bên phải -->
        <TextView
            android:id="@+id/btnCloseExercise"
            android:layout_width="168dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_start_button"
            android:gravity="center"
            android:text="ĐÓNG"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</FrameLayout>