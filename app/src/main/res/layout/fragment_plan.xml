<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollPlan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE"
    android:clipToPadding="false"
    android:paddingBottom="90dp">

    <LinearLayout
        android:id="@+id/layoutPlanContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KẾ HOẠCH"
            android:textColor="#222222"
            android:textSize="35sp"
            android:paddingTop="30dp"
            android:textStyle="bold" />

        <!-- Header chương trình -->
        <LinearLayout
            android:id="@+id/layoutPlanHeader"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_plan_header"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="26dp"
            android:paddingEnd="26dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TẬP CƠ BỤNG"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Giảm mỡ bụng và săn chắc cơ"
                android:textColor="#E0E0E0"
                android:textSize="18sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtRemainingDays"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="29 ngày còn lại"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3%"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Thanh tiến độ giả lập -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:background="#555555">

                <View
                    android:id="@+id/viewProgress"
                    android:layout_width="24dp"
                    android:layout_height="match_parent"
                    android:background="#7B61FF" />

            </FrameLayout>

        </LinearLayout>

        <!-- Danh sách 30 ngày sẽ được thêm bằng Kotlin -->
        <LinearLayout
            android:id="@+id/layoutDayList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical" />

    </LinearLayout>

</ScrollView>