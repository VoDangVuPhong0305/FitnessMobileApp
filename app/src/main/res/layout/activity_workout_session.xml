<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="34dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCloseSession"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#B0B0B0"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSessionInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text=""
                android:textColor="#999999"
                android:textSize="26sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="52dp"
                android:layout_height="52dp" />

        </LinearLayout>

        <!-- Video / hoạt hình bài tập -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF">

            <VideoView
                android:id="@+id/videoSessionExercise"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/txtSessionEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Chưa có hoạt hình"
                android:textColor="#999999"
                android:textSize="18sp"
                android:visibility="gone" />

        </FrameLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="62dp" />

        <!-- Tiêu đề trạng thái: ĐÃ SẴN SÀNG TẬP -->
        <TextView
            android:id="@+id/txtPhaseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="ĐÃ SẴN SÀNG TẬP"
            android:textColor="#222222"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Tên bài tập -->
        <TextView
            android:id="@+id/txtSessionExerciseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="LEO NÚI"
            android:textColor="#555555"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Đồng hồ -->
        <TextView
            android:id="@+id/txtSessionTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="10"
            android:textColor="#111111"
            android:textSize="76sp"
            android:textStyle="bold" />

        <!-- Nút bắt đầu ngay trong màn chuẩn bị -->
        <TextView
            android:id="@+id/btnStartNow"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginStart="42dp"
            android:layout_marginTop="34dp"
            android:layout_marginEnd="42dp"
            android:background="@drawable/bg_session_gray_button"
            android:gravity="center"
            android:text="BẮT ĐẦU NGAY"
            android:textColor="#666666"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Cụm nút khi đang tập -->
        <LinearLayout
            android:id="@+id/layoutExerciseControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnPauseResume"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="42dp"
                android:layout_marginEnd="42dp"
                android:background="@drawable/bg_session_gray_button"
                android:gravity="center"
                android:text="Ⅱ  TẠM DỪNG"
                android:textColor="#666666"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnPreviousExercise"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="|‹  Trước đó"
                    android:textColor="#B0B0B0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="28dp"
                    android:background="#DDDDDD" />

                <TextView
                    android:id="@+id/btnSkip"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Bỏ qua  ›|"
                    android:textColor="#777777"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>