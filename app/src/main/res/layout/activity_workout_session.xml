<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootWorkoutSession"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Màn chuẩn bị / màn tập chính -->
    <LinearLayout
        android:id="@+id/layoutMainSession"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="34dp"
        android:paddingEnd="22dp"
        android:paddingBottom="28dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCloseSession"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#B0B0B0"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtSessionInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text=""
                android:textColor="#999999"
                android:textSize="26sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="52dp"
                android:layout_height="52dp" />

        </LinearLayout>

        <!-- Video bài tập -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF">

            <VideoView
                android:id="@+id/videoSessionExercise"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/txtSessionEmpty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Chưa có hoạt hình"
                android:textColor="#999999"
                android:textSize="18sp"
                android:visibility="gone" />

        </FrameLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="62dp" />

        <TextView
            android:id="@+id/txtPhaseTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="ĐÃ SẴN SÀNG TẬP"
            android:textColor="#222222"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSessionExerciseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="LEO NÚI"
            android:textColor="#555555"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtSessionTimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="10"
            android:textColor="#111111"
            android:textSize="76sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnStartNow"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginStart="42dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="42dp"
            android:background="@drawable/bg_session_gray_button"
            android:gravity="center"
            android:text="BẮT ĐẦU NGAY"
            android:textColor="#666666"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Cụm điều khiển khi đang tập -->
        <LinearLayout
            android:id="@+id/layoutExerciseControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/btnPauseResume"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="42dp"
                android:layout_marginEnd="42dp"
                android:background="@drawable/bg_session_gray_button"
                android:gravity="center"
                android:text="Ⅱ  TẠM DỪNG"
                android:textColor="#666666"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/layoutExerciseNavigation"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="22dp"
                android:layout_marginStart="36dp"
                android:layout_marginEnd="36dp">

                <!-- Vạch giữa cố định ở chính giữa -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:background="#DDDDDD" />

                <!-- Nút Trước đó: nằm bên trái vạch giữa -->
                <TextView
                    android:id="@+id/btnPreviousExercise"
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical|center_horizontal"
                    android:translationX="-90dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:text="←  Trước đó"
                    android:textColor="#777777"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <!-- Nút Bỏ qua: nằm bên phải vạch giữa -->
                <TextView
                    android:id="@+id/btnSkip"
                    android:layout_width="190dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_vertical|center_horizontal"
                    android:translationX="90dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:text="Bỏ qua  →"
                    android:textColor="#777777"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Màn nghỉ ngơi -->
    <LinearLayout
        android:id="@+id/layoutRestScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#252B35"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Phần trên nền tối -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#252B35">

            <!-- Nội dung nghỉ ngơi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:id="@+id/txtRestTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Nghỉ ngơi"
                    android:textColor="#6AF174"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp">

                    <TextView
                        android:id="@+id/btnAddRestTime"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rest_action_button"
                        android:gravity="center"
                        android:text="+20s"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtRestTimer"
                        android:layout_width="0dp"
                        android:layout_height="126dp"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1.25"
                        android:gravity="center"
                        android:text="10"
                        android:textColor="#FFFFFF"
                        android:textSize="76sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnSkipRest"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_rest_action_button"
                        android:gravity="center"
                        android:text="BỎ QUA"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Phần dưới trắng gợi ý cho bài tiếp theo -->
        <LinearLayout
            android:id="@+id/layoutNextExerciseCard"
            android:layout_width="match_parent"
            android:layout_height="460dp"
            android:background="@drawable/bg_rest_bottom_card"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="30dp"
            android:paddingEnd="26dp"
            android:paddingBottom="26dp">

            <TextView
                android:id="@+id/txtRestNextInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tiếp theo 2/7"
                android:textColor="#9B9B9B"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRestNextName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Chống đẩy 00:30"
                android:textColor="#555555"
                android:textSize="26sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="18dp"
                android:layout_weight="1"
                android:background="#FFFFFF">

                <VideoView
                    android:id="@+id/videoRestNextExercise"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/txtRestNextEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Chưa có hoạt hình"
                    android:textColor="#999999"
                    android:textSize="16sp"
                    android:visibility="gone" />

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>