<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <ScrollView
        android:id="@+id/scrollDayDetail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="105dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header đen phía trên -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="#202020"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="38dp"
                android:paddingEnd="24dp"
                android:paddingBottom="28dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center_vertical"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <!-- Dùng weight thay vì Space cố định để không bị đẩy chữ quá thấp -->
                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/txtDayTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NGÀY 1"
                    android:textColor="#FFFFFF"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtWorkoutInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tập Cơ Bụng"
                    android:textColor="#FFFFFF"
                    android:textSize="23sp" />
            </LinearLayout>

            <!-- Khối trắng chứa danh sách bài tập -->
            <LinearLayout
                android:id="@+id/layoutContentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_day_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="28dp"
                android:paddingEnd="22dp"
                android:paddingBottom="28dp">

                <TextView
                    android:id="@+id/txtWorkoutSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 phút, 0 bài tập"
                    android:textColor="#777777"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layoutExerciseList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Nút bắt đầu cố định phía dưới -->
    <TextView
        android:id="@+id/btnStartWorkout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="22dp"
        android:background="@drawable/bg_start_button"
        android:gravity="center"
        android:text="BẮT ĐẦU"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold" />

</FrameLayout>